{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai-quality-bootstrap.implementation-result.v1",
  "type": "object",
  "required": [
    "role_id",
    "implementation_contract_id",
    "summary",
    "files_changed",
    "commands_run",
    "command_results",
    "checks_passed",
    "checks_failed",
    "remaining_failures",
    "scope_deviations",
    "manual_followup"
  ],
  "properties": {
    "role_id": {
      "type": "string",
      "const": "implementer"
    },
    "implementation_contract_id": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commands_run": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "command_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "exit_code",
          "result"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "exit_code": {
            "type": "integer"
          },
          "result": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "checks_passed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checks_failed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "remaining_failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope_deviations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "manual_followup": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "profile_id",
          "obligation",
          "evidence_ref",
          "verification"
        ],
        "properties": {
          "profile_id": {
            "type": "string"
          },
          "obligation": {
            "type": "string"
          },
          "evidence_ref": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "verification": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "test_loop_evidence": {
      "type": "array",
      "description": "One entry per acceptance criterion showing RED→GREEN cycle",
      "items": {
        "type": "object",
        "required": [
          "criterion",
          "test_file",
          "red_result",
          "green_result"
        ],
        "properties": {
          "criterion": {
            "type": "string"
          },
          "test_file": {
            "type": "string"
          },
          "red_result": {
            "type": "string",
            "enum": [
              "fail",
              "error"
            ]
          },
          "green_result": {
            "type": "string",
            "enum": [
              "pass"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "diagnosis_log": {
      "type": "array",
      "description": "Diagnosis Protocol invocations, if any",
      "items": {
        "type": "object",
        "required": [
          "symptom",
          "hypotheses_count",
          "root_cause",
          "debug_tags_cleaned"
        ],
        "properties": {
          "symptom": {
            "type": "string"
          },
          "hypotheses_count": {
            "type": "integer",
            "minimum": 3
          },
          "root_cause": {
            "type": "string"
          },
          "debug_tags_cleaned": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
