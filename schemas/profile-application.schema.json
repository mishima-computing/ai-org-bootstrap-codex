{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai-quality-bootstrap.profile-application.v1",
  "type": "object",
  "required": [
    "profile_id",
    "source_proposal",
    "contract_obligations",
    "acceptance_criteria_refs",
    "required_evidence"
  ],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "source_proposal": {
      "type": "string"
    },
    "contract_obligations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria_refs": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
