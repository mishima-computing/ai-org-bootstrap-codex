{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai-quality-bootstrap.ci-action-writer-result.v1",
  "type": "object",
  "required": [
    "role_id",
    "detected_ecosystem",
    "workflows_read",
    "workflows_changed",
    "commands_added",
    "commands_already_present",
    "checks_added",
    "checks_already_present",
    "gaps",
    "files_changed",
    "negative_control",
    "escalations"
  ],
  "properties": {
    "role_id": {
      "type": "string",
      "enum": [
        "functional-ci-action-writer",
        "security-ci-action-writer",
        "nonfunctional-ci-action-writer"
      ]
    },
    "detected_ecosystem": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workflows_read": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workflows_changed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commands_added": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commands_already_present": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checks_added": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checks_already_present": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(\\.github/workflows/|requirements\\.txt$|pyproject\\.toml$)"
      }
    },
    "negative_control": {
      "type": "object",
      "required": [
        "passed",
        "static_passed",
        "good_input",
        "negative_control"
      ],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "static_passed": {
          "type": "boolean"
        },
        "good_input": {
          "type": "object",
          "additionalProperties": true
        },
        "negative_control": {
          "type": "object",
          "required": [
            "red_observed"
          ],
          "properties": {
            "description": {
              "type": "string"
            },
            "red_observed": {
              "type": ["boolean", "null"]
            },
            "result": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "actionlint": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "escalations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "code",
          "severity",
          "message",
          "evidence"
        ],
        "properties": {
          "type": {
            "type": "string",
            "const": "ci_writer_escalation"
          },
          "code": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor", "info"]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
